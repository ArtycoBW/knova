NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://knova:knova_secret@localhost:5432/knova

JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-in-production-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Основной провайдер
LLM_PROVIDER=centrinvest

# Centrinvest (основной)
CENTRINVEST_API_KEY=hackaton2026
CENTRINVEST_LLM_URL=https://hackai.centrinvest.ru:6630
CENTRINVEST_EMBEDDING_URL=https://hackai.centrinvest.ru:6620
CENTRINVEST_STT_URL=https://hackai.centrinvest.ru:6640

# Gemini (резервный внешний)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Ollama (локальный офлайн)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Размерность эмбеддингов
EMBEDDING_DIMENSIONS=768

# SMTP (пока код в ответе, настрою smtp чуть позже как домен подтвердится)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@knova.dev
SMTP_PASS=
SMTP_FROM="Knova <noreply@knova.dev>"

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

ML_SERVICE_URL=http://localhost:8000

BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin
