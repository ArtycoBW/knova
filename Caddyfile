{$APP_DOMAIN} {
  encode gzip zstd

  request_body {
    max_size 100MB
  }

  handle_path /api/* {
    reverse_proxy backend:3001
  }

  handle /socket.io/* {
    reverse_proxy backend:3001
  }

  handle /uploads/* {
    reverse_proxy backend:3001
  }

  handle /admin/* {
    reverse_proxy backend:3001
  }

  handle {
    reverse_proxy frontend:3000
  }
}

www.{$APP_DOMAIN} {
  redir https://{$APP_DOMAIN}{uri}
}
